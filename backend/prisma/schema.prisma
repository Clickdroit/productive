generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ────────────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  todos            Todo[]
  notes            Note[]
  pomodoroSessions PomodoroSession[]
  habits           Habit[]
  journalEntries   JournalEntry[]
}

// ─── Todo / Task Manager ─────────────────────────────────────
enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum Status {
  TODO
  IN_PROGRESS
  DONE
}

model Todo {
  id          String   @id @default(cuid())
  title       String
  description String?
  priority    Priority @default(MEDIUM)
  status      Status   @default(TODO)
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Notes (Markdown) ────────────────────────────────────────
model Note {
  id        String   @id @default(cuid())
  title     String
  content   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Pomodoro Timer ──────────────────────────────────────────
model PomodoroSession {
  id        String   @id @default(cuid())
  duration  Int      @default(1500) // seconds (25 min)
  type      String   @default("work") // work | break
  completed Boolean  @default(false)
  startedAt DateTime @default(now())
  endedAt   DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Habit Tracker ───────────────────────────────────────────
model Habit {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#8b5cf6")
  icon      String   @default("✅")
  createdAt DateTime @default(now())

  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  completions HabitCompletion[]

  @@index([userId])
}

model HabitCompletion {
  id   String   @id @default(cuid())
  date DateTime

  habitId String
  habit   Habit  @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([habitId])
}

// ─── Journal / Daily Log ─────────────────────────────────────
model JournalEntry {
  id        String   @id @default(cuid())
  date      DateTime
  content   String   @default("")
  mood      String?  // emoji or label
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}
